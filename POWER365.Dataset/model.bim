      {
        "name": "Temps",
        "calculationGroup": {
          "calculationItems": [
            {
              "name": "Actual",
              "expression": "SELECTEDMEASURE()",
              "formatStringDefinition": {
                "expression": "SELECTEDMEASUREFORMATSTRING()"
              },
              "ordinal": 0
            },
            {
              "name": "N-1",
              "expression": "CALCULATE(SELECTEDMEASURE(),SAMEPERIODLASTYEAR(_Dim_Date[Date]))",
              "formatStringDefinition": {
                "expression": "SELECTEDMEASUREFORMATSTRING()"
              },
              "ordinal": 1
            },
            {
              "name": "Delta",
              "expression": [
                "VAR CA = SELECTEDMEASURE()",
                "VAR CAN1 = CALCULATE(SELECTEDMEASURE(),SAMEPERIODLASTYEAR(_Dim_Date[Date]))",
                "",
                "RETURN",
                "",
                "CA - CAN1"
              ],
              "formatStringDefinition": {
                "expression": "SELECTEDMEASUREFORMATSTRING()"
              },
              "ordinal": 2
            },
            {
              "name": "Evol",
              "expression": [
                "VAR CA = SELECTEDMEASURE()",
                "VAR CAN1 = CALCULATE(SELECTEDMEASURE(),SAMEPERIODLASTYEAR(_Dim_Date[Date]))",
                "",
                "RETURN",
                "",
                "DIVIDE( CA - CAN1 , CAN1 , BLANK())"
              ],
              "formatStringDefinition": {
                "expression": "\"0.0 %\""
              },
              "ordinal": 3
            }
          ]
        },
