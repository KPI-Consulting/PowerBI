            ],
            "displayFolder": "HTML",
            "expression": [
              "",
              "VAR _Image1 = \"https://i.ibb.co/kxQQsXL/t-l-chargement-jpeg.jpg\"",
              "RETURN",
              "\"",
              "<style>",
              "<!--",
              "    #imgtourne ",
              "            {",
              "            border-radius: 0px;",
              "            margin-top:0px;",
              "            margin-bottom:0px;",
              "            margin-left: 0px;",
              "            -webkit-animation: rotateAnim 10s linear infinite;",
              "            }",
              "    @keyframes rotateAnim {",
              "                        from {-webkit-transform: rotateY(0);}",
              "                        to {-webkit-transform: rotateY(360deg);}",
              "                            }",
              "-->",
              "</style>",
              "    <img id=\"\"imgtourne\"\" src=\" & _Image1 & \" style='width:85px;height:76px;' alt=\"\"tourne\"\" />",
              "\""
            ],
            "lineageTag": "426a56e7-2124-43c4-bb42-e5a94a3bdec8"
          },
          {
            "name": "Titre_dynamique",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Visuels & titres",
            "expression": "\"Analyses de la catégorie \"&SELECTEDVALUE(Categories[CategoryName])&\" sur l'année \"&SELECTEDVALUE(_Dim_Date[Annee])",
            "lineageTag": "13e5910c-aa0a-4680-a919-772bd453b8a1"
          },
          {
            "name": "Extraction",
            "annotations": [
