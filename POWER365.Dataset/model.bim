                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "            \"Analyse des volumes et chiffres d'affaire par \" ",
              "            & SWITCH( SELECTEDVALUE(Choix_CAT_CLT_REG[Choix_CAT_CLT_REG Commande])",
              "                        ,0,\"Catégories\"",
              "                        ,1,\"Clients\"",
              "                        ,2,\"Régions\")",
              "            & \" sur l'année \"",
              "            & SELECTEDVALUE(_Dim_Date[Annee])"
            ],
            "lineageTag": "ee6e839e-cf32-4b54-84e7-31e785e11118"
          },
          {
            "name": "Arrow_up",
            "annotations": [
