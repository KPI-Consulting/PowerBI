        "dataCategory": "Time",
        "lineageTag": "9b88e928-129c-4464-acf1-c6ee17d4032f",
        "partitions": [
          {
            "name": "_Dim_Date-52530db9-48ba-43a0-8b4d-b48e8814fc42",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Date_debut = #date(2017,1,1),",
                "    Fin_annee = Date.EndOfYear (DateTime.Date (DateTime.LocalNow() )),",
                "    Premiere_date =List.Min(Liste_dates),",
                "    Derniere_date = List.Max(Liste_dates),",
                "",
                "    Duree =  Duration.Days(Fin_annee - Date_debut)+365,",
                "    Source = List.Dates( Date_debut, Duree, #duration(1,0,0,0)),",
                "    #\"Converti en table\" = Table.FromList(Source, Splitter.SplitByNothing(), null, null, ExtraValues.Error),",
                "    Colonne_date = Table.RenameColumns(#\"Converti en table\",{{\"Column1\", \"Date\"}}),",
                "    Change_type_date = Table.TransformColumnTypes(Colonne_date,{{\"Date\", type date}}),",
                "    Ajout_num_mois = Table.AddColumn(Change_type_date, \"Mois\", each Date.Month([Date]), Int64.Type),",
                "    Ajout_mois_long = Table.AddColumn(Ajout_num_mois, \"Nom du mois\", each Date.MonthName([Date]), type text),",
                "    Ajout_annee = Table.AddColumn(Ajout_mois_long, \"Annee\", each Date.Year([Date]), Int64.Type ),",
                "    Ajout_mois_court = Table.AddColumn(Ajout_annee, \"Mois_court\", each Text.Start ([Nom du mois],4), type text),",
                "    Ajout_num_jour_mois = Table.AddColumn(Ajout_mois_court, \"Num_Jour_mois\", each Date.Day([Date]), Int64.Type),",
                "    Ajout_Periode = Table.AddColumn(Ajout_num_jour_mois, \"Periode\", each if [Mois] >= 9 then [Mois]-8 else [Mois]+4,Int64.Type),",
                "    Ajout_Trimestre = Table.AddColumn(Ajout_Periode, \"Trimestre\", each \"Trimestre \" & Text.From(Number.RoundUp([Periode]/3)),type text),",
                "    Ajout_Exercice = Table.AddColumn(Ajout_Trimestre, \"Exercice\", each if [Mois] >=9 then \"Exercice \" & Text.From([Annee]) & \"-\" & Text.From([Annee]+1) else \"Exercice \" & Text.From([Annee]-1) & \"-\" & Text.From([Annee]), type text)",
                "in",
                "    Ajout_Exercice"
              ],
              "type": "m"
            }
          }
        ]
      },
