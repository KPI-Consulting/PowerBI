              "                <tr>",
              "                    <th class = \"\"headerA\"\">   </th>",
              "                    <th class = \"\"headerX\"\" colspan=2 ><span id=\"\"TxTtourne\"\">\" & MAX(_Dim_Date[Annee]) & \"</span></th>  ",
              "                    <th class = \"\"headerX\"\" colspan=2 ><span id=\"\"TxTtourne\"\">\" & MAX(_Dim_Date[Annee])-1 & \"</span></th>",
              "                    <th class = \"\"header1\"\" colspan=2 ><span id=\"\"TxTtourne\"\"> Delta </span></th>",
