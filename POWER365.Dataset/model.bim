          {
            "name": "Tableau_HTML",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "HTML",
            "expression": [
              "",
              "",
              "",
              "/* Mettre en table virtuelle les mesures par catégories en embarquant les mises en forme conditionnelles et les choix de tri*/",
              "VAR _SourceData =",
              "",
              "/* Création de 3 tables par UNION (Catégories + Clients + Régions )*/",
              "UNION(",
              "",
              "/* Création de la table CATEGORIES : */",
              "",
              "WINDOW(0,ABS,100,REL,    /* Le fenetrage permet l'adjonction du ORDER BY pour le tri */",
              "        ",
              "                SUMMARIZE( Categories,",
              "                    Categories[Libelle]",
              "                    ,\"Actual_Qte\", FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Actual\" ), \"#,##0\" )",
              "                    ,\"Actual_CA\", FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Actual\" ), \"#,##0 €\" )",
              "                    ,\"N-1_Qte\", FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"N-1\" ), \"#,##0\" )",
              "                    ,\"N-1_CA\", FORMAT( CALCULATE ( [CA], Temps[Temps] = \"N-1\" ), \"#,##0 €\" )",
              "",
              "                    /* Blocs mise en forme conditionnelle */",
              "",
              "                    ,\"Delta_Qte\", IF(",
              "                                CALCULATE ( [Qte], Temps[Temps] = \"Delta\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" ) ",
              "                                    )",
              "                    ,\"Delta_CA\", IF(",
              "                                CALCULATE ( [CA], Temps[Temps] = \"Delta\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" ) ",
              "                                    )",
              "                    ,\"Evol_Qte\", IF(",
              "                                CALCULATE ( [Qte], Temps[Temps] = \"Evol\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                    )",
              "                    ,\"Evol_CA\", IF(",
              "                                CALCULATE ( [CA], Temps[Temps] = \"Evol\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                    )",
              "                            )",
              "",
              "                /* Blocs de tri */",
              "",
              "                ,ORDERBY(",
              "                            SWITCH(",
              "                                SELECTEDVALUE(Choix_HTML_Rank[Tri])",
              "                                ,1,CALCULATE ( [Qte], Temps[Temps] = \"Actual\" )",
              "                                ,2,CALCULATE ( [CA], Temps[Temps] = \"Actual\" )",
              "                                ,3,CALCULATE ( [Qte], Temps[Temps] = \"N-1\" )",
              "                                ,4,CALCULATE ( [CA], Temps[Temps] = \"N-1\" )",
              "                                ,5,CALCULATE ( [Qte], Temps[Temps] = \"Delta\" )",
              "                                ,6,CALCULATE ( [CA], Temps[Temps] = \"Delta\" )",
              "                                ,7,CALCULATE ( [Qte], Temps[Temps] = \"Evol\" )",
              "                                ,8,CALCULATE ( [CA], Temps[Temps] = \"Evol\" )",
              "                                    )",
              "                        ,DESC)",
              "            )",
              "",
              "/* Création de la table REGION : */",
              ",WINDOW(0,ABS,100,REL,    /* Le fenetrage permet l'adjonction du ORDER BY pour le tri */",
              "    ",
              "                SUMMARIZE( Region,",
              "                    Region[Libelle]",
              "                    ,\"Actual_Qte\", FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Actual\" ), \"#,##0\" )",
              "                    ,\"Actual_CA\", FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Actual\" ), \"#,##0 €\" )",
              "                    ,\"N-1_Qte\", FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"N-1\" ), \"#,##0\" )",
              "                    ,\"N-1_CA\", FORMAT( CALCULATE ( [CA], Temps[Temps] = \"N-1\" ), \"#,##0 €\" )",
              "",
              "                    /* Blocs mise en forme conditionnelle */",
              "",
              "                    ,\"Delta_Qte\", IF(",
              "                                CALCULATE ( [Qte], Temps[Temps] = \"Delta\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" ) ",
              "                                    )",
              "                    ,\"Delta_CA\", IF(",
              "                                CALCULATE ( [CA], Temps[Temps] = \"Delta\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" ) ",
              "                                    )",
              "                    ,\"Evol_Qte\", IF(",
              "                                CALCULATE ( [Qte], Temps[Temps] = \"Evol\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                    )",
              "                    ,\"Evol_CA\", IF(",
              "                                CALCULATE ( [CA], Temps[Temps] = \"Evol\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                    )",
              "                            )",
              "",
              "                /* Blocs de tri */",
              "",
              "                ,ORDERBY(",
              "                            SWITCH(",
              "                                SELECTEDVALUE(Choix_HTML_Rank[Tri])",
              "                                ,1,CALCULATE ( [Qte], Temps[Temps] = \"Actual\" )",
              "                                ,2,CALCULATE ( [CA], Temps[Temps] = \"Actual\" )",
              "                                ,3,CALCULATE ( [Qte], Temps[Temps] = \"N-1\" )",
              "                                ,4,CALCULATE ( [CA], Temps[Temps] = \"N-1\" )",
              "                                ,5,CALCULATE ( [Qte], Temps[Temps] = \"Delta\" )",
              "                                ,6,CALCULATE ( [CA], Temps[Temps] = \"Delta\" )",
              "                                ,7,CALCULATE ( [Qte], Temps[Temps] = \"Evol\" )",
              "                                ,8,CALCULATE ( [CA], Temps[Temps] = \"Evol\" )",
              "                                    )",
              "                        ,DESC)",
              "            ) ",
              "",
              "/* Création de la table CLIENTS : */",
              ",WINDOW(0,ABS,100,REL,    /* Le fenetrage permet l'adjonction du ORDER BY pour le tri */",
              "     ",
              "                SUMMARIZE( Employes,",
              "                    Employes[First_Last]  /*Clients,Clients[CompanyName]*/",
              "                    ,\"Actual_Qte\", FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Actual\" ), \"#,##0\" )",
              "                    ,\"Actual_CA\", FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Actual\" ), \"#,##0 €\" )",
              "                    ,\"N-1_Qte\", FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"N-1\" ), \"#,##0\" )",
              "                    ,\"N-1_CA\", FORMAT( CALCULATE ( [CA], Temps[Temps] = \"N-1\" ), \"#,##0 €\" )",
              "",
              "                    /* Blocs mise en forme conditionnelle */",
              "",
              "                    ,\"Delta_Qte\", IF(",
              "                                CALCULATE ( [Qte], Temps[Temps] = \"Delta\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" ) ",
              "                                )",
              "                    ,\"Delta_CA\", IF(",
              "                                CALCULATE ( [CA], Temps[Temps] = \"Delta\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" ) ",
              "                                )",
              "                    ,\"Evol_Qte\", IF(",
              "                                CALCULATE ( [Qte], Temps[Temps] = \"Evol\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                )",
              "                    ,\"Evol_CA\", IF(",
              "                                CALCULATE ( [CA], Temps[Temps] = \"Evol\" )>=0",
              "                                ,\"<span style='color:#678B18;font-weight:bold;font-size:23px;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                )",
              "                            )",
              "            ",
              "             /* Blocs de tri */",
              "",
              "                ,ORDERBY(",
              "                            SWITCH(",
              "                                SELECTEDVALUE(Choix_HTML_Rank[Tri])",
              "                                ,1,CALCULATE ( [Qte], Temps[Temps] = \"Actual\" )",
              "                                ,2,CALCULATE ( [CA], Temps[Temps] = \"Actual\" )",
              "                                ,3,CALCULATE ( [Qte], Temps[Temps] = \"N-1\" )",
              "                                ,4,CALCULATE ( [CA], Temps[Temps] = \"N-1\" )",
              "                                ,5,CALCULATE ( [Qte], Temps[Temps] = \"Delta\" )",
              "                                ,6,CALCULATE ( [CA], Temps[Temps] = \"Delta\" )",
              "                                ,7,CALCULATE ( [Qte], Temps[Temps] = \"Evol\" )",
              "                                ,8,CALCULATE ( [CA], Temps[Temps] = \"Evol\" )",
              "                                    )",
              "                        ,DESC)",
              "            ) ",
              "    )",
              "",
              "/* Creer un block HTML continu pour les valeurs de chaque ligne du tableau */",
              "VAR _TableRow =",
              "SWITCH(SELECTEDVALUE(Choix_CAT_CLT_REG[Choix_CAT_CLT_REG Commande])",
              "    ,0,CONCATENATEX(",
              "                    _SourceData,",
              "                    IF(LEFT([Libelle],1)=\"☱\",",
              "                    \"<tr>\"",
              "                        & \"<td class=\"\"colA\"\"><span id=\"\"marquee\"\">\" & [Libelle] & \"</span></td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Actual_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Actual_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [N-1_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [N-1_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Delta_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Delta_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Evol_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Evol_CA] & \"</td>\"",
              "                    & \"</tr>\"",
              "                    ,BLANK()",
              "                    ))",
              "    ,1,CONCATENATEX(",
              "                    _SourceData,",
              "                    IF(LEFT([Libelle],1)=\"☲\",",
              "                    \"<tr>\"",
              "                        & \"<td class=\"\"colA\"\"><span id=\"\"marquee\"\">\" & [Libelle] & \"</span></td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Actual_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Actual_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [N-1_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [N-1_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Delta_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Delta_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Evol_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Evol_CA] & \"</td>\"",
              "                    & \"</tr>\"",
              "                    ,BLANK()",
              "                    ))",
              "    ,2,CONCATENATEX(",
              "                    _SourceData,",
              "                    IF(LEFT([Libelle],1)=\"☴\",",
              "                    \"<tr>\"",
              "                        & \"<td class=\"\"colA\"\"><span id=\"\"marquee\"\">\" & [Libelle] & \"</span></td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Actual_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Actual_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [N-1_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [N-1_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Delta_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Delta_CA] & \"</td>\"",
              "                        & \"<td class=\"\"col1\"\">\" & [Evol_Qte] & \"</td>\"",
              "                        & \"<td class=\"\"col2\"\">\" & [Evol_CA] & \"</td>\"",
              "                    & \"</tr>\"",
              "                    ,BLANK()",
              "                    ))",
              "            )",
              "/* Creer une ligne HTML simple pour le total du tableau */",
              "VAR _TotalRow =",
              "                    \"<tf>",
              "                        <td class = \"\"TotA\"\"> Total </td>",
              "                        <td class = \"\"Tot1\"\">\" & FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Actual\" ), \"#,##0\" ) & \"</td>",
              "                        <td class = \"\"Tot2\"\">\" & FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Actual\" ), \"#,##0 €\" ) & \"</td>",
              "                        <td class = \"\"Tot1\"\">\" & FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"N-1\" ), \"#,##0\" ) & \"</td>",
              "                        <td class = \"\"Tot2\"\">\" & FORMAT( CALCULATE ( [CA], Temps[Temps] = \"N-1\" ), \"#,##0 €\" ) & \"</td>",
              "                        <td class = \"\"Tot1\"\">\" & IF(",
              "                                                    CALCULATE ( [Qte], Temps[Temps] = \"Delta\" )>=0",
              "                                                    ,\"<span style='color:#678B18;font-weight:bold;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" )",
              "                                                    , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Delta\" ), \"#,##0\" ) ",
              "                                                    ) & \"</td>",
              "                        <td class = \"\"Tot2\"\">\" & IF(",
              "                                                    CALCULATE ( [CA], Temps[Temps] = \"Delta\" )>=0",
              "                                                    ,\"<span style='color:#678B18;font-weight:bold;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" )",
              "                                                    , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Delta\" ), \"#,##0 €\" ) ",
              "                                                    ) & \"</td>",
              "                        <td class = \"\"Tot1\"\">\" & IF(",
              "                                                    CALCULATE ( [Qte], Temps[Temps] = \"Evol\" )>=0",
              "                                                    ,\"<span style='color:#678B18;font-weight:bold;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                                    , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [Qte], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                                    ) & \"</td>",
              "                        <td class = \"\"Tot2\"\">\" & IF(",
              "                                                    CALCULATE ( [CA], Temps[Temps] = \"Evol\" )>=0",
              "                                                    ,\"<span style='color:#678B18;font-weight:bold;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" )",
              "                                                    , \"<span id=\"\"negatif1\"\" style='color:#C42222;'</span>\"& FORMAT( CALCULATE ( [CA], Temps[Temps] = \"Evol\" ), \"#0.0 %\" ) ",
              "                                                    ) & \"</td>",
              "                        <td class = \"\"Tot3\"\">  </td>",
              "                    </tf>\"",
              "",
              "RETURN",
              "        \"<style>",
              "            #negatif1",
              "                {",
              "                animation: blinker 3s linear infinite;",
              "                font-size:23px;",
              "                font-weight:bold;",
              "                }",
              "                @keyframes blinker ",
              "                    {",
              "                    60% {opacity: 0;}",
              "                    }",
              "            #marquee",
              "                {",
              "                animation: 5s linear infinite slidein;",
              "                }",
              "                @keyframes slidein ",
              "                {",
              "                from { margin-left: 50%; }",
              "                to { margin-left: -50%; }",
              "                }",
              "            #TxTtourne ",
              "                {",
              "                animation-name: spin, depth;",
              "                animation-timing-function: linear;",
              "                animation-iteration-count: infinite;",
              "                animation-duration: 6s;",
              "                }",
              "                @keyframes ",
              "                spin {",
              "                    0% {",
              "                        transform: rotateY(0deg);",
              "                        }",
              "                    100% {",
              "                        transform: rotateY(-360deg);",
              "                        }",
